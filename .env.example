# Runtime: development or production.
NODE_ENV=development
PORT=3000

# Generate with: openssl rand -hex 32
# This is required in production. Keep it private and stable between restarts.
SESSION_SECRET=replace-with-a-long-random-secret

# Required to run the loopback-only password administration command.
ADMIN_SECRET=replace-with-a-different-long-random-secret

# Public origin used to build share-preview URLs (no trailing slash).
PUBLIC_URL=http://localhost:3000

# Optional: override the JSON data-store path.
STORE_PATH=

# Optional: override the upstream Bracket City puzzle directory.
BRACKET_CITY_PUZZLE_URL=https://d2gknrezp32xyk.cloudfront.net/puzzles
